    "eslint-import-resolver-typescript": "^4",
    "eslint-plugin-import-x": "^4",
    "eslint-plugin-n": "^17",
    "jiti": "^2",
    "npm-run-all2": "^7",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=22.22.0"
  }
