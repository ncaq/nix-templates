    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.20.0",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-n": "18.2.1",
    "jiti": "2.7.0",
    "npm-run-all2": "9.0.2",
    "prettier": "3.9.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=22.22.2"
  }
