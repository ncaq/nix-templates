{
  "extraKnownMarketplaces": {
    "konoka": {
      "source": {
        "source": "github",
        "repo": "ncaq/konoka",
        "ref": "v1.1.0"
      }
    }
  },
  "enabledPlugins": {
    "kyosei@konoka": true
  },
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(actionlint:*)",
      "Bash(deadnix:*)",
      "Bash(editorconfig-checker:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh workflow list:*)",
      "Bash(git add:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git stash list:*)",
      "Bash(git status:*)",
      "Bash(git tag:*)",
      "Bash(nix build:*)",
      "Bash(nix develop:*)",
      "Bash(nix eval:*)",
      "Bash(nix flake:*)",
      "Bash(nix fmt:*)",
      "Bash(nix search:*)",
      "Bash(nix-fast-build:*)",
      "Bash(nixfmt:*)",
      "Bash(npm ci:*)",
      "Bash(npm exec --no:*)",
      "Bash(npm run build:*)",
      "Bash(npm run fix:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run test:*)",
      "Bash(npm test:*)",
      "Bash(prettier:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt:*)",
      "Bash(statix:*)",
      "Bash(typos:*)",
      "Bash(zizmor:*)"
    ],
    "deny": ["Bash(npx:*)", "Bash(pnpm:*)", "Bash(pnpx:*)", "Bash(yarn:*)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Stop",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && nix fmt",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
